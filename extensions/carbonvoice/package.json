{
  "name": "@openclaw/carbonvoice",
  "version": "2026.3.14",
  "description": "OpenClaw Carbon Voice channel plugin",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openclaw/openclaw.git",
    "directory": "extensions/carbonvoice"
  },
  "dependencies": {
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@openclaw/plugin-sdk": "workspace:*",
    "openclaw": "workspace:*"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.14"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "carbonvoice",
      "label": "Carbon Voice",
      "selectionLabel": "Carbon Voice",
      "docsPath": "/channels/carbonvoice",
      "docsLabel": "carbonvoice",
      "blurb": "Carbon Voice API webhooks and text replies (voice/TTS on the Carbon Voice side).",
      "order": 72
    },
    "install": {
      "npmSpec": "@openclaw/carbonvoice",
      "localPath": "extensions/carbonvoice",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.14"
    },
    "compat": {
      "pluginApi": ">=2026.3.14"
    },
    "build": {
      "openclawVersion": "2026.3.14"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    },
    "releaseChecks": {
      "rootDependencyMirrorAllowlist": ["socket.io-client"]
    }
  }
}
